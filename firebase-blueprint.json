{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "FarmingPlan": {
      "title": "Farming Plan",
      "description": "A saved farming plan generated by the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user who saved this plan." },
        "location": { "type": "string" },
        "bestCrop": { "type": "string" },
        "farmingPlan": { "type": "string" },
        "sevenDayActionPlan": { "type": "array", "items": { "type": "string" } },
        "commonMistakes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "location", "bestCrop", "farmingPlan"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/plans/{planId}": {
      "schema": "FarmingPlan",
      "description": "Saved farming plans."
    }
  }
}
